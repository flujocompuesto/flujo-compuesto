---
// Navegación compartida con menú hamburguesa en móvil.
// links: [{ href, label }], cta: { href, label }
interface Props {
  links: { href: string; label: string }[];
  cta: { href: string; label: string };
}
const { links, cta } = Astro.props;
---

<header class="nav" id="site-nav">
  <div class="wrap nav__inner">
    <a href="/" class="brand" aria-label="Flujo Compuesto — inicio">
      <svg width="30" height="30" viewBox="0 0 64 64" aria-hidden="true">
        <rect width="64" height="64" rx="14" fill="#24344B" />
        <path d="M12 44 C24 44, 26 20, 52 16" fill="none" stroke="#1DBE60" stroke-width="6" stroke-linecap="round" />
        <circle cx="52" cy="16" r="6" fill="#2EE272" />
      </svg>
      <span>Flujo Compuesto</span>
    </a>

    <button class="nav__burger" aria-label="Abrir menú" aria-expanded="false" aria-controls="nav-menu">
      <span></span><span></span><span></span>
    </button>

    <div class="nav__menu" id="nav-menu">
      <nav class="nav__links" aria-label="Navegación principal">
        {links.map((l) => <a href={l.href}>{l.label}</a>)}
      </nav>
      <a href={cta.href} class="btn btn--primary nav__cta">{cta.label}</a>
    </div>
  </div>
</header>

<style>
  .nav { position: sticky; top: 0; z-index: 50; background: rgba(240,241,242,.9); backdrop-filter: saturate(180%) blur(12px); border-bottom: 1px solid var(--line); }
  .nav__inner { display: flex; align-items: center; gap: 20px; height: 68px; position: relative; }
  .brand { display: inline-flex; align-items: center; gap: 10px; font-weight: 700; font-size: 1.15rem; color: var(--ink); }
  .brand:hover { color: var(--ink); }

  .nav__menu { display: flex; align-items: center; gap: 26px; margin-left: auto; }
  .nav__links { display: flex; gap: 26px; }
  .nav__links a { color: var(--ink-soft); font-weight: 600; font-size: .95rem; }
  .nav__links a:hover { color: var(--green-deep); }
  .nav__cta { padding: 10px 20px; font-size: .95rem; }

  /* Botón hamburguesa (oculto en desktop) */
  .nav__burger { display: none; margin-left: auto; width: 44px; height: 44px; border: 0; background: transparent; cursor: pointer; padding: 10px; flex-direction: column; justify-content: center; gap: 5px; }
  .nav__burger span { display: block; height: 2.5px; width: 100%; background: var(--navy); border-radius: 2px; transition: transform .2s ease, opacity .2s ease; }

  @media (max-width: 860px) {
    .nav__burger { display: flex; }
    .nav__menu {
      position: absolute; top: calc(100% + 1px); left: -24px; right: -24px;
      flex-direction: column; align-items: stretch; gap: 0; margin-left: 0;
      background: var(--card); border-bottom: 1px solid var(--line);
      box-shadow: var(--shadow-lg); padding: 8px 24px 20px;
      display: none;
    }
    .nav.is-open .nav__menu { display: flex; }
    .nav__links { flex-direction: column; gap: 0; }
    .nav__links a { padding: 14px 4px; border-bottom: 1px solid var(--line); font-size: 1.05rem; }
    .nav__cta { margin-top: 16px; justify-content: center; padding: 14px 20px; font-size: 1rem; }

    /* Hamburguesa → X cuando está abierto */
    .nav.is-open .nav__burger span:nth-child(1) { transform: translateY(7.5px) rotate(45deg); }
    .nav.is-open .nav__burger span:nth-child(2) { opacity: 0; }
    .nav.is-open .nav__burger span:nth-child(3) { transform: translateY(-7.5px) rotate(-45deg); }
  }
</style>

<script>
  const nav = document.getElementById('site-nav');
  if (nav) {
    const burger = nav.querySelector('.nav__burger');
    const setOpen = (open: boolean) => {
      nav.classList.toggle('is-open', open);
      burger?.setAttribute('aria-expanded', String(open));
      burger?.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
    };
    burger?.addEventListener('click', () => setOpen(!nav.classList.contains('is-open')));
    // Cerrar al tocar un enlace
    nav.querySelectorAll('.nav__menu a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
    // Cerrar si se vuelve a desktop
    window.addEventListener('resize', () => { if (window.innerWidth > 860) setOpen(false); });
  }
</script>
