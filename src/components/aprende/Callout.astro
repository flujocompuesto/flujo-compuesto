---
// Caja de "idea clave" (💡) al estilo del sitio.
interface Props { title?: string; icon?: string; }
const { title, icon = '💡' } = Astro.props;
---
<aside class="callout">
  <div class="callout__ic" aria-hidden="true">{icon}</div>
  <div class="callout__body">
    {title && <div class="callout__title">{title}</div>}
    <div class="callout__text"><slot /></div>
  </div>
</aside>

<style>
  .callout { display: flex; gap: 14px; align-items: flex-start; background: linear-gradient(135deg, var(--green-100), #EAFBF1); border: 1px solid #BEEBCF; border-radius: var(--radius-lg); padding: 20px 22px; margin: 28px 0; }
  .callout__ic { font-size: 1.5rem; line-height: 1.3; flex-shrink: 0; }
  .callout__title { font-weight: 800; color: var(--green-deep); margin-bottom: 4px; }
  .callout__text { color: var(--navy); line-height: 1.65; }
  .callout__text :global(p) { margin: 0; }
</style>
