---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';

interface Props {
  title: string;
  description: string;
  slug: string;
  category: string;
  icon?: string;
  readingTime?: string;
  updated?: Date;
}
const { title, description, slug, category, icon = '📄', readingTime = '5 min', updated } = Astro.props;
const site = 'https://flujocompuesto.com';
const url = `${site}/aprende/${slug}`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  inLanguage: 'es',
  articleSection: category,
  ...(updated ? { dateModified: updated.toISOString() } : {}),
  author: { '@type': 'Person', name: 'Ivan Herrera', url: `${site}/sobre-mi`, jobTitle: 'Ingeniero · Especialista en QA' },
  publisher: { '@type': 'Organization', name: 'Flujo Compuesto', url: site },
  mainEntityOfPage: url,
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: site + '/' },
    { '@type': 'ListItem', position: 2, name: 'Aprende', item: site + '/aprende' },
    { '@type': 'ListItem', position: 3, name: title, item: url },
  ],
};
---

<Base title={`${title} — Flujo Compuesto`} description={description} path={`/aprende/${slug}`} ogType="article" schema={[articleSchema, breadcrumbSchema]}>
  <Nav
    links={[
      { href: '/aprende', label: 'Aprende' },
      { href: '/calculadora', label: 'Calculadora' },
      { href: '/sobre-mi', label: 'Sobre mí' },
    ]}
    cta={{ href: '/guia', label: 'Guía gratis' }}
  />

  <article class="art">
    <div class="wrap art-narrow">
      <nav class="crumbs" aria-label="Ruta">
        <a href="/">Inicio</a> <span aria-hidden="true">›</span>
        <a href="/aprende">Aprende</a> <span aria-hidden="true">›</span>
        <span class="crumbs__cur">{category}</span>
      </nav>

      <header class="art-head">
        <span class="art-cat">{icon} {category}</span>
        <h1>{title}</h1>
        <p class="art-lead">{description}</p>
        <div class="art-byline">
          <div class="art-byline__av" aria-hidden="true">IH</div>
          <div>Por <a href="/sobre-mi"><strong>Ivan Herrera</strong></a> · Ingeniero, no financiero<br>
          <span class="muted">Lectura de {readingTime}{updated ? ` · Actualizado ${updated.toLocaleDateString('es', { month: 'long', year: 'numeric' })}` : ''}</span></div>
        </div>
      </header>

      <div class="prose">
        <slot />
      </div>

      <!-- CTA de conversión al final de cada artículo -->
      <aside class="art-cta card">
        <h2>¿Listo para dar el primer paso?</h2>
        <p class="muted">Empieza con la guía gratuita <em>De cero a tu primer portafolio, sin miedo</em> — la mentalidad y los pasos concretos, en un solo lugar.</p>
        <a href="/guia" class="btn btn--primary btn--lg">Leer la guía gratis →</a>
      </aside>

      <p class="art-disc muted">Contenido educativo e informativo. No constituye asesoría de inversión, financiera ni fiscal personalizada. Invertir conlleva riesgos, incluida la posible pérdida de capital.</p>
    </div>
  </article>

  <footer class="footer">
    <div class="wrap center" style="font-size:.85rem">
      <p style="margin:0">© {new Date().getFullYear()} Flujo Compuesto · Contenido educativo, no asesoría de inversión · <a href="/aprende" style="color:rgba(255,255,255,.8)">Aprende</a> · <a href="/sobre-mi" style="color:rgba(255,255,255,.8)">Sobre mí</a></p>
    </div>
  </footer>
</Base>

<style>
  .nav { position: sticky; top: 0; z-index: 50; background: rgba(240,241,242,.85); backdrop-filter: saturate(180%) blur(12px); border-bottom: 1px solid var(--line); }
  .nav__inner { display: flex; align-items: center; gap: 24px; height: 68px; }
  .brand { display: inline-flex; align-items: center; gap: 10px; font-weight: 700; font-size: 1.15rem; color: var(--ink); }
  .nav__links { display: flex; gap: 26px; margin-left: auto; }
  .nav__links a { color: var(--ink-soft); font-weight: 600; font-size: .95rem; }
  .nav__cta { padding: 10px 20px; font-size: .95rem; }

  .art { padding: 32px 0 72px; }
  .art-narrow { max-width: 720px; }

  .crumbs { font-size: .85rem; color: var(--muted); margin-bottom: 24px; display: flex; gap: 8px; flex-wrap: wrap; }
  .crumbs a { color: var(--muted); font-weight: 600; }
  .crumbs a:hover { color: var(--green-deep); }
  .crumbs__cur { color: var(--ink-soft); }

  .art-head { margin-bottom: 32px; }
  .art-cat { display: inline-block; font-size: .8rem; font-weight: 700; color: var(--green-deep); background: var(--green-100); padding: 5px 12px; border-radius: 100px; margin-bottom: 14px; }
  .art-head h1 { margin: 0 0 14px; }
  .art-lead { font-size: 1.18rem; color: var(--ink-soft); font-weight: 500; line-height: 1.6; }
  .art-byline { display: flex; align-items: center; gap: 14px; margin-top: 22px; font-size: .95rem; }
  .art-byline__av { width: 44px; height: 44px; border-radius: 50%; background: var(--navy); color: var(--green-bright); font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: .9rem; }

  /* Prosa: estilos de lectura para el contenido MDX (Markdown estándar) */
  .prose { font-size: 1.1rem; line-height: 1.8; color: var(--ink-soft); }
  .prose :global(h2) { font-size: clamp(1.4rem, 2.6vw, 1.8rem); color: var(--navy); margin: 40px 0 14px; letter-spacing: -0.01em; }
  .prose :global(h3) { font-size: 1.2rem; color: var(--navy); margin: 28px 0 10px; }
  .prose :global(p) { margin: 0 0 18px; }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 18px; padding-left: 24px; display: grid; gap: 8px; }
  .prose :global(li) { line-height: 1.7; }
  .prose :global(strong) { color: var(--navy); font-weight: 700; }
  .prose :global(a) { color: var(--green-deep); text-decoration: underline; text-underline-offset: 2px; }
  .prose :global(blockquote) { margin: 26px 0; padding: 18px 24px; background: var(--green-100); border-left: 4px solid var(--green); border-radius: 0 12px 12px 0; font-weight: 700; color: var(--navy); font-size: 1.15rem; line-height: 1.5; }
  .prose :global(blockquote p) { margin: 0; }
  .prose :global(table) { width: 100%; border-collapse: collapse; margin: 24px 0; font-size: .96rem; }
  .prose :global(th), .prose :global(td) { text-align: left; padding: 10px 14px; border-bottom: 1px solid var(--line); }
  .prose :global(th) { color: var(--muted); font-size: .8rem; text-transform: uppercase; letter-spacing: .05em; }
  .prose :global(hr) { border: 0; border-top: 1px solid var(--line); margin: 36px 0; }
  .prose :global(code) { background: var(--gray-100); padding: 2px 6px; border-radius: 5px; font-size: .92em; }

  .art-cta { margin: 48px 0 24px; text-align: center; border: 2px solid var(--green); }
  .art-cta h2 { font-size: 1.4rem; margin-bottom: 8px; }
  .art-cta p { margin-bottom: 18px; }

  .art-disc { font-size: .84rem; line-height: 1.7; border-top: 1px solid var(--line); padding-top: 18px; }

  .footer { background: var(--ink); color: rgba(255,255,255,.7); padding: 28px 0; }
  .footer a { color: rgba(255,255,255,.8); }

  @media (max-width: 720px) { .nav__links { display: none; } }
</style>
