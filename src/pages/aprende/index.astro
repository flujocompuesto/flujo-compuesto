---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('aprende', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);

// Agrupar por categoría preservando el orden de aparición
const byCategory = new Map<string, typeof entries>();
for (const e of entries) {
  const arr = byCategory.get(e.data.category) ?? [];
  arr.push(e);
  byCategory.set(e.data.category, arr);
}

const site = 'https://flujocompuesto.com';
const listSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Aprende — Flujo Compuesto',
  description: 'Biblioteca de educación financiera e inversión: aprende desde cero, gratis.',
  url: site + '/aprende',
  hasPart: entries.map((e) => ({ '@type': 'Article', headline: e.data.title, url: `${site}/aprende/${e.id}` })),
};
---

<Base
  title="Aprende — Educación financiera e inversión desde cero | Flujo Compuesto"
  description="Biblioteca gratuita para aprender a invertir desde Latinoamérica: interés compuesto, qué es una acción, ETFs, cómo leer una empresa y más. Explicado sin tecnicismos."
  path="/aprende"
  schema={listSchema}
>
  <Nav
    links={[
      { href: '/aprende', label: 'Aprende' },
      { href: '/calculadora', label: 'Calculadora' },
      { href: '/sobre-mi', label: 'Sobre mí' },
    ]}
    cta={{ href: '/guia', label: 'Guía gratis' }}
  />

  <main class="apr">
    <div class="wrap">
      <div class="apr-head center">
        <span class="eyebrow">Biblioteca gratuita</span>
        <h1>Aprende a invertir, desde cero</h1>
        <p class="lead" style="margin:14px auto 0">Todo lo que aprendí en 13 años, explicado sin tecnicismos. Empieza por donde estés.</p>
      </div>

      {[...byCategory.entries()].map(([cat, list]) => (
        <section class="apr-group">
          <h2 class="apr-cat">{cat}</h2>
          <div class="apr-grid">
            {list.map((e) => (
              <a href={`/aprende/${e.id}`} class="apr-card card">
                <div class="apr-card__ic" aria-hidden="true">{e.data.icon}</div>
                <div class="apr-card__title">{e.data.title}</div>
                <div class="apr-card__desc muted">{e.data.description}</div>
                <div class="apr-card__meta">Leer · {e.data.readingTime} →</div>
              </a>
            ))}
          </div>
        </section>
      ))}

      <div class="apr-note muted center">Más lecciones en camino. Se agregan progresivamente.</div>
    </div>
  </main>

  <footer class="footer">
    <div class="wrap center" style="font-size:.85rem">
      <p style="margin:0">© {new Date().getFullYear()} Flujo Compuesto · Contenido educativo, no asesoría de inversión · <a href="/" style="color:rgba(255,255,255,.8)">Inicio</a></p>
    </div>
  </footer>
</Base>

<style>
  .nav { position: sticky; top: 0; z-index: 50; background: rgba(240,241,242,.85); backdrop-filter: saturate(180%) blur(12px); border-bottom: 1px solid var(--line); }
  .nav__inner { display: flex; align-items: center; gap: 24px; height: 68px; }
  .brand { display: inline-flex; align-items: center; gap: 10px; font-weight: 700; font-size: 1.15rem; color: var(--ink); }
  .nav__links { display: flex; gap: 26px; margin-left: auto; }
  .nav__links a { color: var(--ink-soft); font-weight: 600; font-size: .95rem; }
  .nav__cta { padding: 10px 20px; font-size: .95rem; }

  .apr { padding: 48px 0 72px; }
  .apr-head { max-width: 620px; margin: 0 auto 48px; }
  .apr-group { margin-bottom: 44px; }
  .apr-cat { font-size: 1.3rem; margin-bottom: 18px; padding-bottom: 10px; border-bottom: 2px solid var(--line); }
  .apr-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .apr-card { display: flex; flex-direction: column; text-decoration: none; color: inherit; transition: transform .15s ease, box-shadow .15s ease; }
  .apr-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); color: inherit; }
  .apr-card__ic { font-size: 1.8rem; margin-bottom: 10px; }
  .apr-card__title { font-weight: 800; font-size: 1.1rem; color: var(--navy); line-height: 1.25; margin-bottom: 8px; }
  .apr-card__desc { font-size: .92rem; line-height: 1.55; flex: 1; }
  .apr-card__meta { margin-top: 14px; font-size: .85rem; font-weight: 700; color: var(--green-deep); }
  .apr-note { margin-top: 20px; font-size: .95rem; }

  .footer { background: var(--ink); color: rgba(255,255,255,.7); padding: 28px 0; }
  .footer a { color: rgba(255,255,255,.8); }

  @media (max-width: 900px) { .apr-grid { grid-template-columns: 1fr; } .nav__links { display: none; } }
</style>
