---
import Base from '../layouts/Base.astro';

// ── Schema FAQ: ayuda a rankear y a que la IA cite respuestas ──
const faqs = [
  {
    q: '¿Necesito saber de finanzas para empezar?',
    a: 'No. Flujo Compuesto está diseñado para quien tiene con qué invertir pero nunca ha invertido. Empezamos desde cero: qué es una acción, qué es un ETF y cómo armar tu primer portafolio con una estrategia de bajo costo y largo plazo.',
  },
  {
    q: '¿Cuánto dinero necesito para invertir?',
    a: 'Menos de lo que crees. Lo importante no es cuánto empiezas, sino empezar temprano y ser constante: gracias al interés compuesto, el tiempo hace la mayor parte del trabajo. Te enseñamos a hacerlo con la cantidad con la que hoy te sientas cómodo.',
  },
  {
    q: '¿Qué filosofía de inversión enseñan?',
    a: 'Inversión de largo plazo, diversificada y de bajo costo, en la línea de Bogleheads y de divulgadores como Ben Felix: fondos indexados en vez de intentar adivinar el mercado. Es el enfoque que la evidencia respalda para el inversionista promedio.',
  },
  {
    q: '¿Esto es asesoría financiera?',
    a: 'No. Flujo Compuesto es contenido educativo, no asesoría de inversión personalizada. Te damos el conocimiento y las herramientas para que tomes tus propias decisiones con confianza.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base
  title="Flujo Compuesto — De cero a tu primer portafolio"
  description="Aprende a poner tu dinero a trabajar. Educación financiera e inversión de largo plazo y bajo costo, para construir tu primer portafolio paso a paso — sin ruido ni promesas de hacerte rico rápido."
  path="/"
  schema={faqSchema}
>
  <!-- ══════════════ NAV ══════════════ -->
  <header class="nav">
    <div class="wrap nav__inner">
      <a href="/" class="brand" aria-label="Flujo Compuesto — inicio">
        <svg width="30" height="30" viewBox="0 0 64 64" aria-hidden="true">
          <rect width="64" height="64" rx="14" fill="#10715C" />
          <path d="M12 44 C24 44, 26 20, 52 16" fill="none" stroke="#E0A93C" stroke-width="6" stroke-linecap="round" />
          <circle cx="52" cy="16" r="6" fill="#E0A93C" />
        </svg>
        <span>Flujo Compuesto</span>
      </a>
      <nav class="nav__links">
        <a href="#filosofia">Filosofía</a>
        <a href="#camino">El camino</a>
        <a href="#faq">Preguntas</a>
      </nav>
      <a href="#freebie" class="btn btn--primary nav__cta">Guía gratis</a>
    </div>
  </header>

  <!-- ══════════════ HERO ══════════════ -->
  <section class="hero">
    <div class="wrap hero__grid">
      <div class="hero__copy">
        <span class="eyebrow">Educación financiera + Inversión</span>
        <h1>Tu dinero no debería estar dormido en el banco.</h1>
        <p class="lead">
          Ganas bien, pero tu dinero pierde contra la inflación cada año que no lo inviertes.
          Te enseñamos, de cero, a construir tu <strong>primer portafolio</strong> con una estrategia
          de largo plazo y bajo costo. Sin ruido, sin adivinar el mercado, sin promesas de hacerte rico rápido.
        </p>
        <div class="hero__actions">
          <a href="#freebie" class="btn btn--primary btn--lg">Empieza gratis →</a>
          <a href="#filosofia" class="btn btn--ghost btn--lg">Ver la filosofía</a>
        </div>
        <p class="hero__trust muted">
          🌱 Filosofía Boglehead · Largo plazo · Bajo costo — el enfoque que respalda la evidencia
        </p>
      </div>

      <!-- Curva de interés compuesto -->
      <div class="hero__viz card">
        <div class="viz__label muted">El poder de empezar hoy</div>
        <svg viewBox="0 0 340 220" class="viz__svg" role="img" aria-label="Curva de crecimiento del interés compuesto en el tiempo">
          <defs>
            <linearGradient id="fill" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#10715C" stop-opacity="0.22" />
              <stop offset="100%" stop-color="#10715C" stop-opacity="0" />
            </linearGradient>
          </defs>
          <!-- ejes -->
          <line x1="30" y1="190" x2="325" y2="190" stroke="#E7E1D6" stroke-width="2" />
          <line x1="30" y1="20" x2="30" y2="190" stroke="#E7E1D6" stroke-width="2" />
          <!-- área -->
          <path d="M30 190 C120 188, 200 176, 260 130 C295 100, 312 55, 320 30 L320 190 Z" fill="url(#fill)" />
          <!-- curva -->
          <path d="M30 190 C120 188, 200 176, 260 130 C295 100, 312 55, 320 30" fill="none" stroke="#10715C" stroke-width="3.5" stroke-linecap="round" />
          <!-- punto final -->
          <circle cx="320" cy="30" r="6" fill="#E0A93C" />
          <text x="36" y="184" font-size="11" fill="#5B6B66">hoy</text>
          <text x="285" y="184" font-size="11" fill="#5B6B66">+30 años</text>
        </svg>
        <p class="viz__note muted">
          Cada año que esperas, el interés compuesto tiene menos tiempo para trabajar por ti.
        </p>
      </div>
    </div>
  </section>

  <!-- ══════════════ PROBLEMA ══════════════ -->
  <section class="section section--tight problema">
    <div class="wrap">
      <div class="center">
        <span class="eyebrow">El costo de no empezar</span>
        <h2>El dinero quieto no es seguro. Es una pérdida lenta.</h2>
      </div>
      <div class="grid grid-3" style="margin-top:44px">
        <div class="card">
          <div class="ic">📉</div>
          <h3>La inflación te cobra en silencio</h3>
          <p class="muted">Lo que hoy compras con $100, en unos años lo compras con más. El efectivo parado pierde poder cada año — es una comisión invisible.</p>
        </div>
        <div class="card">
          <div class="ic">⏳</div>
          <h3>El tiempo perdido no vuelve</h3>
          <p class="muted">El mayor activo de un inversionista no es el dinero, es el tiempo. Empezar 5 años tarde puede costar cientos de miles al final del camino.</p>
        </div>
        <div class="card">
          <div class="ic">🎰</div>
          <h3>El ruido te paraliza (o te quema)</h3>
          <p class="muted">Acciones de moda, cripto, "tips" de gurús. Sin una filosofía clara terminas sin invertir, o invirtiendo en lo equivocado.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════ FILOSOFÍA / SOLUCIÓN ══════════════ -->
  <section id="filosofia" class="section filosofia">
    <div class="wrap filosofia__grid">
      <div>
        <span class="eyebrow">La filosofía</span>
        <h2>Invertir bien es aburrido. Y por eso funciona.</h2>
        <p class="lead" style="margin-bottom:28px">
          No tratamos de ganarle al mercado. Capturamos su rendimiento con constancia, a bajo costo
          y con la mirada puesta en décadas — el enfoque de los Bogleheads y de divulgadores como Ben Felix.
        </p>
        <ul class="principios">
          <li><span>01</span><div><strong>Largo plazo.</strong> El tiempo en el mercado le gana a intentar adivinar el momento.</div></li>
          <li><span>02</span><div><strong>Bajo costo.</strong> Cada punto de comisión se come tu interés compuesto. Menos costo, más para ti.</div></li>
          <li><span>03</span><div><strong>Diversificación.</strong> No apuestas a una empresa; te vuelves dueño de miles con un solo fondo indexado.</div></li>
          <li><span>04</span><div><strong>Constancia.</strong> Inviertes con método, sin importar el titular del día. Los hábitos vencen a la suerte.</div></li>
        </ul>
      </div>
      <div class="filosofia__quote card">
        <div class="quote__mark">"</div>
        <p class="quote__text">Invertir no requiere un conocimiento profundo de economía. Cualquier persona común puede tener éxito capturando consistentemente los retornos del mercado con fondos indexados de bajo costo.</p>
        <div class="quote__by">— Filosofía que enseñamos, en la línea de Ben Felix</div>
      </div>
    </div>
  </section>

  <!-- ══════════════ FREEBIE / LEAD MAGNET ══════════════ -->
  <section id="freebie" class="section freebie">
    <div class="wrap">
      <div class="freebie__card card">
        <div class="freebie__copy">
          <span class="eyebrow" style="background:var(--amber-soft);color:#8a5f14">Gratis para empezar</span>
          <h2>La guía: <em>De cero a tu primer portafolio</em></h2>
          <p class="lead">
            Una guía práctica + calculadora interactiva de interés compuesto para que veas, con tus propios
            números, cuánto puede crecer tu dinero. Déjame tu correo y te la envío.
          </p>
          <ul class="checks">
            <li>✓ Los 4 principios para invertir sin miedo</li>
            <li>✓ Calculadora: cuánto tendrás en 10, 20 y 30 años</li>
            <li>✓ El primer paso concreto para abrir tu portafolio</li>
          </ul>
        </div>
        <div class="freebie__form">
          <!-- Placeholder: conectaremos a ConvertKit/Beehiiv/Resend en el siguiente paso -->
          <form class="lead-form" name="lead-magnet" onsubmit="return false;">
            <label for="nombre">Nombre</label>
            <input id="nombre" name="nombre" type="text" placeholder="Tu nombre" autocomplete="given-name" required />
            <label for="email">Correo</label>
            <input id="email" name="email" type="email" placeholder="tu@correo.com" autocomplete="email" required />
            <button type="submit" class="btn btn--amber btn--lg" style="width:100%;justify-content:center">Quiero la guía gratis</button>
            <p class="form__fine muted">Sin spam. Contenido educativo, no asesoría de inversión. Cancela cuando quieras.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════ EL CAMINO / VALUE LADDER ══════════════ -->
  <section id="camino" class="section camino">
    <div class="wrap">
      <div class="center">
        <span class="eyebrow">Cómo te acompañamos</span>
        <h2>Un camino, a tu ritmo</h2>
        <p class="lead center" style="margin:14px auto 0">Empiezas gratis y avanzas solo si quieres ir más lejos.</p>
      </div>
      <div class="ladder" style="margin-top:48px">
        <div class="ladder__step card">
          <div class="ladder__tag">Gratis</div>
          <h3>La guía + calculadora</h3>
          <p class="muted">Tu primer contacto con la filosofía y la mecánica. Sin costo, sin compromiso.</p>
        </div>
        <div class="ladder__step card">
          <div class="ladder__tag">Curso</div>
          <h3>El sistema completo</h3>
          <p class="muted">Un curso self-paced que te lleva paso a paso de cero a tu primer portafolio armado.</p>
        </div>
        <div class="ladder__step card ladder__step--hl">
          <div class="ladder__tag ladder__tag--hl">Comunidad</div>
          <h3>Aprende acompañado</h3>
          <p class="muted">Comunidad privada, sesiones en vivo y herramientas para mantener el rumbo mes a mes.</p>
        </div>
        <div class="ladder__step card">
          <div class="ladder__tag">1 : 1</div>
          <h3>Acompañamiento personal</h3>
          <p class="muted">Sesiones individuales para miembros que quieren un plan hecho a su medida.</p>
        </div>
      </div>
      <p class="center muted" style="margin-top:28px;font-size:.95rem">
        🚧 Estamos construyendo esto en público. Únete a la lista y sé de los primeros en acceder.
      </p>
    </div>
  </section>

  <!-- ══════════════ FAQ ══════════════ -->
  <section id="faq" class="section faq">
    <div class="wrap faq__wrap">
      <div class="center">
        <span class="eyebrow">Preguntas frecuentes</span>
        <h2>Lo que probablemente te estás preguntando</h2>
      </div>
      <div class="faq__list" style="margin-top:40px">
        {faqs.map((f) => (
          <details class="faq__item">
            <summary>{f.q}</summary>
            <p class="muted">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════ CTA FINAL ══════════════ -->
  <section class="section cta-final">
    <div class="wrap center">
      <h2 style="color:#fff">Empieza hoy. Tu yo de dentro de 20 años lo agradecerá.</h2>
      <p class="lead center" style="color:rgba(255,255,255,.85);margin:16px auto 30px">
        Da el primer paso con la guía gratis. Sin costo, sin riesgo, sin jerga.
      </p>
      <a href="#freebie" class="btn btn--amber btn--lg">Descargar la guía gratis →</a>
    </div>
  </section>

  <!-- ══════════════ FOOTER ══════════════ -->
  <footer class="footer">
    <div class="wrap footer__inner">
      <div class="footer__brand">
        <div class="brand">
          <svg width="26" height="26" viewBox="0 0 64 64" aria-hidden="true">
            <rect width="64" height="64" rx="14" fill="#10715C" />
            <path d="M12 44 C24 44, 26 20, 52 16" fill="none" stroke="#E0A93C" stroke-width="6" stroke-linecap="round" />
            <circle cx="52" cy="16" r="6" fill="#E0A93C" />
          </svg>
          <span>Flujo Compuesto</span>
        </div>
        <p class="muted" style="margin-top:12px;max-width:340px;font-size:.92rem">
          Educación financiera e inversión de largo plazo para construir tu primer portafolio.
        </p>
      </div>
      <div class="footer__disc muted">
        <p><strong>Aviso importante:</strong> Todo el contenido de Flujo Compuesto es de carácter
        <strong>educativo e informativo</strong>. No constituye asesoría de inversión, financiera, legal ni
        fiscal personalizada. Invertir conlleva riesgos, incluida la posible pérdida de capital. Antes de
        tomar decisiones, considera tu situación particular y, si lo necesitas, consulta a un profesional licenciado.</p>
        <p style="margin-top:14px">© {new Date().getFullYear()} Flujo Compuesto. Todos los derechos reservados.</p>
      </div>
    </div>
  </footer>
</Base>

<style>
  /* NAV */
  .nav { position: sticky; top: 0; z-index: 50; background: rgba(250,247,241,.82); backdrop-filter: saturate(180%) blur(12px); border-bottom: 1px solid var(--line); }
  .nav__inner { display: flex; align-items: center; gap: 24px; height: 68px; }
  .brand { display: inline-flex; align-items: center; gap: 10px; font-family: var(--font-serif); font-weight: 700; font-size: 1.15rem; color: var(--ink); }
  .brand:hover { color: var(--ink); }
  .nav__links { display: flex; gap: 26px; margin-left: auto; }
  .nav__links a { color: var(--ink-soft); font-weight: 600; font-size: .95rem; }
  .nav__cta { padding: 10px 20px; font-size: .95rem; }

  /* HERO */
  .hero { padding: 72px 0 40px; }
  .hero__grid { display: grid; grid-template-columns: 1.1fr .9fr; gap: 56px; align-items: center; }
  .hero__actions { display: flex; gap: 14px; flex-wrap: wrap; margin: 30px 0 20px; }
  .hero__trust { font-size: .95rem; }
  .hero__viz { padding: 24px; }
  .viz__label { font-weight: 700; font-size: .85rem; letter-spacing: .04em; text-transform: uppercase; margin-bottom: 10px; }
  .viz__svg { width: 100%; height: auto; }
  .viz__note { font-size: .9rem; margin: 12px 0 0; }

  /* PROBLEMA */
  .ic { font-size: 2rem; margin-bottom: 12px; }
  .problema h3 { margin-bottom: 8px; }

  /* FILOSOFÍA */
  .filosofia { background: linear-gradient(180deg, #fff, var(--cream)); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .filosofia__grid { display: grid; grid-template-columns: 1.15fr .85fr; gap: 56px; align-items: center; }
  .principios { list-style: none; margin: 0; padding: 0; display: grid; gap: 18px; }
  .principios li { display: flex; gap: 16px; align-items: flex-start; }
  .principios span { flex-shrink: 0; font-family: var(--font-serif); font-weight: 700; color: var(--amber); font-size: 1.1rem; width: 30px; }
  .filosofia__quote { background: var(--green-deep); border: 0; color: #fff; padding: 40px 34px; }
  .quote__mark { font-family: var(--font-serif); font-size: 4rem; line-height: .5; color: var(--amber); height: 34px; }
  .quote__text { font-family: var(--font-serif); font-size: 1.35rem; line-height: 1.4; color: #fff; }
  .quote__by { color: rgba(255,255,255,.7); font-size: .9rem; font-weight: 600; }

  /* FREEBIE */
  .freebie__card { display: grid; grid-template-columns: 1.1fr .9fr; gap: 44px; padding: 44px; align-items: center; border: 2px solid var(--amber); }
  .checks { list-style: none; padding: 0; margin: 20px 0 0; display: grid; gap: 10px; font-weight: 600; color: var(--ink-soft); }
  .lead-form label { display: block; font-weight: 700; font-size: .9rem; margin: 14px 0 6px; }
  .lead-form input { width: 100%; padding: 14px 16px; border: 1.5px solid var(--line); border-radius: 12px; font-size: 1rem; font-family: var(--font-sans); background: var(--cream); }
  .lead-form input:focus { outline: none; border-color: var(--green); }
  .lead-form button { margin-top: 22px; }
  .form__fine { font-size: .82rem; margin: 12px 0 0; text-align: center; }

  /* LADDER */
  .ladder { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .ladder__step { position: relative; }
  .ladder__step h3 { margin: 10px 0 8px; }
  .ladder__tag { display: inline-block; font-weight: 700; font-size: .78rem; letter-spacing: .05em; text-transform: uppercase; color: var(--muted); background: var(--green-100); padding: 5px 12px; border-radius: 100px; }
  .ladder__step--hl { border-color: var(--green); box-shadow: var(--shadow-lg); }
  .ladder__tag--hl { background: var(--green); color: #fff; }

  /* FAQ */
  .faq__wrap { max-width: 760px; }
  .faq__item { border: 1px solid var(--line); border-radius: var(--radius); background: var(--card); padding: 4px 22px; margin-bottom: 12px; }
  .faq__item summary { cursor: pointer; font-weight: 700; font-size: 1.08rem; padding: 18px 0; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq__item summary::-webkit-details-marker { display: none; }
  .faq__item summary::after { content: '+'; color: var(--green); font-size: 1.5rem; font-weight: 400; }
  .faq__item[open] summary::after { content: '–'; }
  .faq__item p { padding: 0 0 18px; margin: 0; }

  /* CTA FINAL */
  .cta-final { background: var(--green-deep); }

  /* FOOTER */
  .footer { background: var(--ink); color: rgba(255,255,255,.7); padding: 56px 0 40px; }
  .footer .brand { color: #fff; }
  .footer .brand:hover { color: #fff; }
  .footer__inner { display: grid; grid-template-columns: 1fr 1.4fr; gap: 44px; }
  .footer__disc { font-size: .84rem; line-height: 1.7; }
  .footer .muted { color: rgba(255,255,255,.55); }

  @media (max-width: 900px) {
    .hero__grid, .filosofia__grid, .freebie__card, .footer__inner { grid-template-columns: 1fr; }
    .ladder { grid-template-columns: 1fr 1fr; }
    .nav__links { display: none; }
    .hero { padding: 40px 0 20px; }
    .freebie__card { padding: 28px; }
  }
  @media (max-width: 560px) {
    .ladder { grid-template-columns: 1fr; }
  }
</style>
